# scripts/migrate-schema.js and scripts/reset-firestore.js.
#
# Expected files (each gitignored via root .gitignore "service-account*.json"):
#   credentials/service-account-dev.json
#   credentials/service-account-prod.json
#
# These are restored locally from Bitwarden, not stored in git.
